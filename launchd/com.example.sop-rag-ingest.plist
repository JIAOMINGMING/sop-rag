<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Auto-ingest watcher (macOS): re-indexes whenever docs/ changes.
     Replace YOUR_USERNAME, then:
       cp launchd/com.example.sop-rag-ingest.plist ~/Library/LaunchAgents/
       launchctl load ~/Library/LaunchAgents/com.example.sop-rag-ingest.plist -->
<dict>
    <key>Label</key>
    <string>com.example.sop-rag-ingest</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOUR_USERNAME/sop-rag/watch_ingest.sh</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>/Users/YOUR_USERNAME/sop-rag/docs</string>
    </array>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/sop-rag/logs/watch_ingest.err</string>
</dict>
</plist>
